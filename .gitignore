# Kitbash_AI — gitignore
# Track source (Python, design docs, cartridges, manifests).
# Exclude runtime state, indexes, models, logs, caches.

# Python caches
__pycache__/
*.pyc
*.pyo

# Runtime state / persistence
*.db
*.sqlite
*.sqlite3
*.idx
*.jsonl
*.pt
*.pth
*.gz
*.bin

# Live runtime data dirs
/data/state/
/data/subconscious/
/grains/*.json
/phantom_tracker.json

# Runtime operation logs (e.g. ops.log, ops.log.1) — internal operational
# stream, never meant to be committed.
*.log

# Virtual envs
.venv/
venv/
env/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# Local git remote config (keep repo portable)
.git/
