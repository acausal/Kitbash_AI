{
  "test_cases": [
    {
      "name": "basic_addition",
      "function": "safe_evaluate",
      "input": {"expression": "2 + 3", "precision": 10},
      "expected_output": {"status": "success", "result": 5, "expression": "2 + 3"}
    },
    {
      "name": "order_of_operations",
      "function": "safe_evaluate",
      "input": {"expression": "2 + 2 * 3", "precision": 10},
      "expected_output": {"status": "success", "result": 8, "expression": "2 + 2 * 3"}
    },
    {
      "name": "parentheses",
      "function": "safe_evaluate",
      "input": {"expression": "(2 + 2) * 3", "precision": 10},
      "expected_output": {"status": "success", "result": 12}
    },
    {
      "name": "exponentiation_caret",
      "function": "safe_evaluate",
      "input": {"expression": "2 ^ 3", "precision": 10},
      "expected_output": {"status": "success", "result": 8}
    },
    {
      "name": "function_sqrt",
      "function": "safe_evaluate",
      "input": {"expression": "sqrt(16)", "precision": 10},
      "expected_output": {"status": "success", "result": 4.0}
    },
    {
      "name": "constant_pi",
      "function": "safe_evaluate",
      "input": {"expression": "pi * 2", "precision": 5},
      "expected_output": {"status": "success", "result_min": 6.28, "result_max": 6.29}
    },
    {
      "name": "precision_rounding",
      "function": "safe_evaluate",
      "input": {"expression": "1 / 3", "precision": 2},
      "expected_output": {"status": "success", "result": 0.33}
    },
    {
      "name": "division_by_zero",
      "function": "safe_evaluate",
      "input": {"expression": "1 / 0", "precision": 10},
      "expected_output": {"status": "error", "reason_includes": "Division by zero"}
    },
    {
      "name": "math_domain_error",
      "function": "safe_evaluate",
      "input": {"expression": "sqrt(-1)", "precision": 10},
      "expected_output": {"status": "error", "reason_includes": "domain error"}
    },
    {
      "name": "undefined_variable",
      "function": "safe_evaluate",
      "input": {"expression": "x + 2", "precision": 10},
      "expected_output": {"status": "error", "reason_includes": "undefined variable"}
    },
    {
      "name": "invalid_syntax",
      "function": "safe_evaluate",
      "input": {"expression": "2 +", "precision": 10},
      "expected_output": {"status": "error", "reason_includes": "invalid syntax"}
    },
    {
      "name": "cli_roundtrip",
      "function": "cli",
      "input": {"expression": "2 + 2 * 3", "precision": 10},
      "expected_output": {"status": "success", "result": 8, "cli_rc": 0}
    },
    {
      "name": "cli_error_rc",
      "function": "cli",
      "input": {"expression": "1 / 0", "precision": 10},
      "expected_output": {"cli_rc": 1, "status": "error"}
    }
  ]
}
