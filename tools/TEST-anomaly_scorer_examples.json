# TEST-anomaly_scorer_examples.json
# Test cases for Anomaly Scorer v1
# Validates anomaly detection, severity scoring, and cause suggestion

{
  "test_cases": [
    {
      "name": "simple_fp_rate_spike",
      "description": "Grain false positive rate spikes 3x above baseline",
      "function": "detect_false_positive_rate_anomalies",
      "input": {
        "grain_stats": {
          "grain_42": {
            "fp_count": 12,
            "fp_rate": 0.30,
            "total_uses": 40,
            "most_confused_with": [137, 89],
            "window": "2026-07-14T10:00:00Z to 2026-07-14T14:00:00Z"
          }
        },
        "historical_baseline": {
          "grain_42": {
            "mean_fp_rate": 0.10,
            "std_fp_rate": 0.02,
            "n_observations": 50,
            "period": "last_7_days"
          }
        }
      },
      "expected_output": {
        "anomaly_type": "sudden_increase_false_positives",
        "baseline_rate": 0.10,
        "observed_rate": 0.30,
        "deviation_magnitude": 3.0,
        "severity_min": 0.55,
        "severity_max": 0.70
      }
    },
    {
      "name": "high_magnitude_spike",
      "description": "Grain FP rate spikes 5.17x (real-world example)",
