# TEST-pattern_confidence_scorer_examples.json
# Test cases for Pattern Confidence Scorer v1
# Validates scoring logic, metrics, and flag detection

{
  "test_cases": [
    {
      "name": "simple_sequence_high_precision",
      "description": "Pattern fires often and succeeds most times",
      "pattern": {
        "pattern_id": "p1",
        "sequence": ["tokenizer", "negation_detector"],
        "frequency": 40
      },
      "traces": [
        {"trace_id": "t1", "sequence": ["tokenizer", "negation_detector", "svo_extractor"], "outcome": "success"},
        {"trace_id": "t2", "sequence": ["tokenizer", "negation_detector", "json_filter"], "outcome": "success"},
        {"trace_id": "t3", "sequence": ["tokenizer", "negation_detector", "text_search"], "outcome": "success"},
        {"trace_id": "t4", "sequence": ["tokenizer", "negation_detector", "line_filter"], "outcome": "failure"},
        {"trace_id": "t5", "sequence": ["tokenizer", "negation_detector", "datetime_utils"], "outcome": "failure"},
        {"trace_id": "t6", "sequence": ["json_filter", "text_search"], "outcome": "success"},
        {"trace_id": "t7", "sequence": ["line_filter", "datetime_utils"], "outcome": "success"},
        {"trace_id": "t8", "sequence": ["line_filter", "text_search"], "outcome": "failure"}
      ],
      "expected_output": {
        "metrics": {
          "precision": 0.6,
          "recall": 0.75,
          "f1_score": 0.67,
          "true_positive_rate": 0.75,
          "false_positive_rate": 0.4,
          "specificity": 0.67,
          "support": 5
        },
        "interpretation": {
          "reliability": "medium",
          "confidence_flag": "none"
        },
        "details": {
          "true_positives": 3,
          "false_positives": 2,
          "true_negatives": 2,
          "false_negatives": 1,
          "total_observations": 8
        }
      }
    },
    {
      "name": "collision_pattern_high_precision",
      "description": "Collision pair fires frequently, mostly indicates false positive",
      "pattern": {
        "pattern_id": "p2",
        "collision_pair": [42, 137],
        "collision_count": 23
      },
      "dream_bucket_observations": [
        {"type": "false_positive", "returned_id": 42, "correct_id": 137, "outcome": "false_positive"},
        {"type": "false_positive", "returned_id": 42, "correct_id": 137, "outcome": "false_positive"},
        {"type": "false_positive", "returned_id": 42, "correct_id": 137, "outcome": "false_positive"},
        {"type": "false_positive", "returned_id": 42, "correct_id": 200, "outcome": "false_positive"},
        {"type": "collision_cluster", "pivot_id": 42, "collision_ids": [137, 89], "outcome": "collision"},
        {"type": "success", "grain_id": 137, "outcome": "success"}
      ],
      "expected_output": {
        "metrics": {
          "precision": 0.75,
          "support": 4
        },
        "interpretation": {
          "reliability": "medium",
          "confidence_flag": "low_sample_size"
        }
      }
    },
    {
      "name": "low_sample_size_warning",
      "description": "Pattern fires only 8 times (below threshold n=20)",
      "pattern": {
        "pattern_id": "p3",
        "sequence": ["json_filter", "text_search"],
        "frequency": 8
      },
      "traces": [
        {"trace_id": "t1", "sequence": ["json_filter", "text_search"], "outcome": "success"},
        {"trace_id": "t2", "sequence": ["json_filter", "text_search"], "outcome": "success"},
        {"trace_id": "t3", "sequence": ["json_filter", "text_search"], "outcome": "failure"},
        {"trace_id": "t4", "sequence": ["other", "tools"], "outcome": "success"},
        {"trace_id": "t5", "sequence": ["other", "tools"], "outcome": "failure"}
      ],
      "expected_output": {
        "metrics": {
          "precision": 0.67,
          "recall": 1.0,
          "f1_score": 0.8,
          "support": 3
        },
        "interpretation": {
          "reliability": "medium",
          "confidence_flag": "low_sample_size",
          "sample_size_note": "n=3 (recommend n≥20 for reliable scoring)"
        }
      }
    },
    {
      "name": "high_false_positive_rate",
      "description": "Pattern fires often but mostly on failures",
      "pattern": {
        "pattern_id": "p4",
        "sequence": ["invalid_tool", "broken_config"],
        "frequency": 30
      },
      "traces": [
        {"trace_id": "t1", "sequence": ["invalid_tool", "broken_config"], "outcome": "failure"},
        {"trace_id": "t2", "sequence": ["invalid_tool", "broken_config"], "outcome": "failure"},
        {"trace_id": "t3", "sequence": ["invalid_tool", "broken_config"], "outcome": "failure"},
        {"trace_id": "t4", "sequence": ["invalid_tool", "broken_config"], "outcome": "failure"},
        {"trace_id": "t5", "sequence": ["invalid_tool", "broken_config"], "outcome": "failure"},
        {"trace_id": "t6", "sequence": ["valid_tool", "good_config"], "outcome": "success"},
        {"trace_id": "t7", "sequence": ["valid_tool", "good_config"], "outcome": "success"},
        {"trace_id": "t8", "sequence": ["valid_tool", "good_config"], "outcome": "success"},
        {"trace_id": "t9", "sequence": ["valid_tool", "good_config"], "outcome": "success"},
        {"trace_id": "t10", "sequence": ["valid_tool", "good_config"], "outcome": "success"}
      ],
      "expected_output": {
        "metrics": {
          "precision": 0.0,
          "recall": 0.0,
          "f1_score": 0.0,
          "false_positive_rate": 1.0,
          "support": 5
        },
        "interpretation": {
          "reliability": "low",
          "confidence_flag": "high_false_positive_rate"
        }
      }
    },
    {
      "name": "decay_by_age",
      "description": "Pattern scores decay over time; older observations weighted less",
      "pattern": {
        "pattern_id": "p5",
        "sequence": ["A", "B"],
        "frequency": 20
      },
      "traces": [
        {"trace_id": "t1", "sequence": ["A", "B"], "outcome": "success", "timestamp": "2026-07-14T10:00:00Z"},
        {"trace_id": "t2", "sequence": ["A", "B"], "outcome": "success", "timestamp": "2026-07-14T11:00:00Z"},
        {"trace_id": "t3", "sequence": ["A", "B"], "outcome": "failure", "timestamp": "2026-06-14T10:00:00Z"},
        {"trace_id": "t4", "sequence": ["A", "B"], "outcome": "failure", "timestamp": "2026-06-14T11:00:00Z"},
        {"trace_id": "t5", "sequence": ["X", "Y"], "outcome": "success", "timestamp": "2026-07-14T12:00:00Z"}
      ],
      "decay_params": {
        "decay_factor": 0.99,
        "reference_date": "2026-07-14"
      },
      "expected_output": {
        "original_metrics": {
          "precision": 0.5,
          "recall": 1.0
        },
        "decayed_metrics": {
          "precision": 0.67,
          "recall": 1.0,
          "note": "Recent successes weighted higher; old failures down-weighted"
        },
        "age_weight_oldest": {
          "age_days": 30,
          "weight_factor": 0.74
        }
      }
    }
  ]
}
